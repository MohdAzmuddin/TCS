public class Main {
    public static void main(String[] args) {
        int arr[] = {2,4,6,8,10};
        int target = 6;

        int index = -1;

        for(int i=0; i<arr.length; i++){
            if(arr[i] == target){
                index = i;
                break;
            }
        }

        System.out.println(index);
    }
}
